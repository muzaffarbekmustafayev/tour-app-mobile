# ── NavaiTour mobil — muhit sozlamalari (NAMUNA) ────────────────
# Bu faylni `.env` nomi bilan nusxalab, qiymatlarni to'ldiring:
#   cp .env.example .env
# O'zgartirgandan keyin Metro'ni qayta ishga tushiring: npx expo start -c

# API manzili — bo'sh qoldirilsa dev rejimda kompyuter IP avtomatik aniqlanadi.
# Qo'lda belgilash kerak bo'lsa (masalan boshqa tarmoqda):
# EXPO_PUBLIC_API_URL=http://192.168.1.xx:5000/api

# ── Google OAuth 2.0 ─────────────────────────────────────────
# Web client — backend/frontend .env dagi bilan bir xil (bir Google Cloud loyihasi)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com

# Android client — o'sha Google Cloud loyihasida "Android" turidagi
# OAuth client yaratib, ID sini bu yerga yozing:
#   Package name: com.navaitour.app
#   SHA-1: keytool -list -v -keystore %USERPROFILE%\.android\debug.keystore -alias androiddebugkey -storepass android
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com

# iOS client (faqat iOS build kerak bo'lsa):
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com
